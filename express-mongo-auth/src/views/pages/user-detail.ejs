<%- include("../partials/head") %>
<%- include("../partials/navbar") %>
<%- include("../partials/flash") %>

<div class="container" style="margin-top: 30px;">
  <div class="card">
    <div class="card-content">
      <span class="card-title">Detalle de usuario</span>

      <ul class="collection">
        <li class="collection-item"><strong>ID:</strong> <%= user.id %></li>
        <li class="collection-item"><strong>Nombre:</strong> <%= user.name %> <%= user.lastName %></li>
        <li class="collection-item"><strong>Email:</strong> <%= user.email %></li>
        <li class="collection-item"><strong>Teléfono:</strong> <%= user.phoneNumber %></li>
        <li class="collection-item"><strong>Fecha de nacimiento:</strong> <%= new Date(user.birthdate).toLocaleDateString() %></li>
        <li class="collection-item"><strong>Edad:</strong> <%= user.age %></li>
        <li class="collection-item"><strong>Dirección:</strong> <%= user.adress || 'No registrada' %></li>
        <li class="collection-item"><strong>URL foto:</strong> <%= user.url_profile || 'No registrada' %></li>
        <li class="collection-item"><strong>Roles:</strong> <%= user.roles.join(", ") %></li>
        <li class="collection-item"><strong>Creado:</strong> <%= new Date(user.createdAt).toLocaleString() %></li>
      </ul>

      <a href="/dashboard-admin" class="btn teal darken-2">Volver</a>
    </div>
  </div>
</div>

<%- include("../partials/scripts") %>