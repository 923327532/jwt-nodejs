<%- include("../partials/head") %>
<%- include("../partials/navbar") %>
<%- include("../partials/flash") %>

<div class="container" style="margin-top: 30px;">
  <div class="row">
    <div class="col s12 m4">
      <div class="card center-align">
        <div class="card-content">
          <img
            src="<%= user.url_profile || 'https://i.pravatar.cc/300' %>"
            alt="Foto de perfil"
            class="circle responsive-img"
            style="width: 140px; height: 140px; object-fit: cover; margin: 0 auto 16px;"
          />
          <span class="card-title"><%= user.name %> <%= user.lastName %></span>
          <p><strong>Email:</strong> <%= user.email %></p>
          <p><strong>Edad:</strong> <%= user.age ?? 'No disponible' %></p>
          <p><strong>Rol(es):</strong> <%= user.roles.join(", ") %></p>
        </div>
      </div>
    </div>

    <div class="col s12 m8">
      <div class="card">
        <div class="card-content">
          <span class="card-title">Mi cuenta</span>

          <form action="/profile" method="POST">
            <div class="row">
              <div class="input-field col s12 m6">
                <input id="name" name="name" type="text" value="<%= user.name %>" required />
                <label class="active" for="name">Nombres</label>
              </div>

              <div class="input-field col s12 m6">
                <input id="lastName" name="lastName" type="text" value="<%= user.lastName %>" required />
                <label class="active" for="lastName">Apellidos</label>
              </div>

              <div class="input-field col s12 m6">
                <input id="phoneNumber" name="phoneNumber" type="text" value="<%= user.phoneNumber %>" required />
                <label class="active" for="phoneNumber">Teléfono</label>
              </div>

              <div class="input-field col s12 m6">
                <input id="birthdate" name="birthdate" type="date" value="<%= new Date(user.birthdate).toISOString().split('T')[0] %>" required />
                <label class="active" for="birthdate">Fecha de nacimiento</label>
              </div>

              <div class="input-field col s12">
                <input id="url_profile" name="url_profile" type="url" value="<%= user.url_profile || '' %>" />
                <label class="active" for="url_profile">URL de foto</label>
              </div>

              <div class="input-field col s12">
                <input id="adress" name="adress" type="text" value="<%= user.adress || '' %>" />
                <label class="active" for="adress">Dirección</label>
              </div>
            </div>

            <button class="btn teal darken-2" type="submit">Guardar cambios</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include("../partials/scripts") %>